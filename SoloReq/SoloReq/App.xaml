<Application x:Class="SoloReq.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Font families -->
            <FontFamily x:Key="JetBrainsMono">pack://application:,,,/Fonts/#JetBrains Mono</FontFamily>
            <FontFamily x:Key="Inter">pack://application:,,,/Fonts/#Inter</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>
            <FontFamily x:Key="UIFont">Segoe UI</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
