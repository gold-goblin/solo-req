<Window x:Class="SoloReq.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=">_ О программе"
        Width="400" Height="310"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None" AllowsTransparency="false"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}">
            <Button Content="✕" Click="CloseClick" HorizontalAlignment="Right"
                    FontSize="12" Width="40" Height="32"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Logo -->
            <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                       FontSize="28" FontWeight="Bold" Margin="0,0,0,8">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF479C" Offset="0"/>
                        <GradientStop Color="#FF9248" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                &gt;_ solo-req
            </TextBlock>

            <!-- Version -->
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <!-- Description -->
            <TextBlock Text="$ Проект solo-log.ru" HorizontalAlignment="Center"
                       FontFamily="{StaticResource MonoFont}" FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <!-- Link -->
            <TextBlock HorizontalAlignment="Center" Cursor="Hand"
                       MouseLeftButtonDown="Link_Click"
                       FontFamily="{StaticResource MonoFont}" FontSize="12">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF479C" Offset="0"/>
                        <GradientStop Color="#FF9248" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                <Underline>solo-log.ru/projects/solo-req</Underline>
            </TextBlock>

            <!-- Settings folder link -->
            <TextBlock HorizontalAlignment="Center" Cursor="Hand"
                       MouseLeftButtonDown="SettingsFolder_Click"
                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,16,0,0">
                <Underline>$ Папка настроек</Underline>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
