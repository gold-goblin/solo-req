<Window x:Class="SoloReq.Views.UserAgentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=">_ User-Agent"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None" AllowsTransparency="false"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF479C" Offset="0"/>
                            <GradientStop Color="#FF9248" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    &gt;_
                </TextBlock>
                <TextBlock x:Name="TitleText" FontFamily="{StaticResource MonoFont}" FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕" Click="CloseClick" HorizontalAlignment="Right"
                    FontSize="12" Width="40" Height="32"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="16,8,16,16">
            <!-- Название -->
            <TextBlock Text="$ Название" FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                     Background="{DynamicResource EditorBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,4" Margin="0,0,0,8"/>

            <!-- Значение UA -->
            <TextBlock Text="$ Значение UA" FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding UaString, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                     Background="{DynamicResource EditorBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,4" Margin="0,0,0,8"/>

            <!-- Версия -->
            <TextBlock Text="$ Версия" FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                     Background="{DynamicResource EditorBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,4" Margin="0,0,0,8"/>

            <!-- ОС -->
            <TextBlock Text="$ ОС" FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Os, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                     Background="{DynamicResource EditorBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,4" Margin="0,0,0,8"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Отмена" Click="CancelClick"
                        FontFamily="{StaticResource MonoFont}" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        Cursor="Hand" Padding="12,6" Margin="0,0,8,0"/>
                <Button x:Name="BtnSave" Content="&gt;&gt; Сохранить" Click="SaveClick"
                        FontFamily="{StaticResource MonoFont}" FontSize="12"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="12,6"
                        IsEnabled="{Binding CanSave}">
                    <Button.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF479C" Offset="0"/>
                            <GradientStop Color="#FF9248" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Foreground>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
