<UserControl x:Class="SoloReq.Views.ResponsePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:converters="clr-namespace:SoloReq.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status Line -->
        <Border Grid.Row="0" Margin="0,0,0,4">
            <TextBlock x:Name="StatusLineText" FontFamily="{StaticResource MonoFont}" FontSize="13"
                       Text="{Binding StatusLine}" Padding="4"
                       Foreground="{DynamicResource TextSecondaryBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Style="{DynamicResource BlogTabControl}">
            <!-- Body Tab -->
            <TabItem Header="// Тело" Style="{DynamicResource BlogTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                        <Button Content="Форматировать" Command="{Binding FormatResponseCommand}"
                                Style="{DynamicResource ToolbarTagButton}" Margin="0,0,4,0"/>
                        <Button Content="Копировать" Command="{Binding CopyBodyCommand}"
                                Style="{DynamicResource ToolbarTagButton}" Margin="0,0,4,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveBodyCommand}"
                                Style="{DynamicResource ToolbarTagButton}" Margin="0,0,4,0"/>
                        <Button Content="Поиск" Command="{Binding ToggleSearchCommand}"
                                Style="{DynamicResource ToolbarTagButton}"/>
                    </StackPanel>

                    <!-- Search Bar -->
                    <Border Grid.Row="1" CornerRadius="8" Margin="0,0,0,4"
                            Background="{DynamicResource EditorBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="6,4"
                            Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchTextBox" Grid.Column="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="13"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     Padding="2,0"/>

                            <TextBlock Grid.Column="1" Text="{Binding MatchCountDisplay}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="4,0"/>

                            <!-- Previous match (chevron-up) -->
                            <Button Grid.Column="2" Command="{Binding PreviousMatchCommand}"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                <Path Data="M18,15 L12,9 L6,15"
                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                      Stretch="Uniform" Width="12" Height="12"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>

                            <!-- Next match (chevron-down) -->
                            <Button Grid.Column="3" Command="{Binding NextMatchCommand}"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                <Path Data="M6,9 L12,15 L18,9"
                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                      Stretch="Uniform" Width="12" Height="12"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>

                            <!-- Case sensitive toggle (Aa) -->
                            <Button Grid.Column="4" Content="Аа" Command="{Binding ToggleCaseSensitiveCommand}"
                                    FontFamily="{StaticResource MonoFont}" FontSize="12"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                                    Padding="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchCaseSensitive}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentPinkBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Close search (x) -->
                            <Button Grid.Column="5" Command="{Binding CloseSearchCommand}"
                                    Width="28" Height="28" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                <Path Data="M18,6 L6,18 M6,6 L18,18"
                                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                      Stretch="Uniform" Width="10" Height="10"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" CornerRadius="8" ClipToBounds="True"
                            Background="{DynamicResource EditorBackgroundBrush}">
                        <Border.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource EditorScrollBarStyle}"/>
                        </Border.Resources>
                    <avalonedit:TextEditor x:Name="ResponseBodyEditor"
                                           FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           Background="Transparent"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           ShowLineNumbers="True" IsReadOnly="True"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Headers Tab -->
            <TabItem Header="// Заголовки" Style="{DynamicResource BlogTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Копировать все" Command="{Binding CopyHeadersCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,4"
                            FontFamily="{StaticResource MonoFont}" FontSize="11"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Padding="8,4" Cursor="Hand"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Headers}" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True"
                              Style="{DynamicResource BlogDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Заголовок" Binding="{Binding Key}" Width="*"/>
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Cookies Tab -->
            <TabItem Header="// Cookies" Style="{DynamicResource BlogTabItem}">
                <DataGrid ItemsSource="{Binding Cookies}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True"
                          Style="{DynamicResource BlogDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"/>
                        <DataGridTextColumn Header="Домен" Binding="{Binding Domain}" Width="Auto"/>
                        <DataGridTextColumn Header="Путь" Binding="{Binding Path}" Width="Auto"/>
                        <DataGridTemplateColumn Header="HttpOnly" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding HttpOnly, Mode=OneWay}"
                                              IsHitTestVisible="False"
                                              Style="{DynamicResource BlogDataGridCheckBox}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Secure" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Secure, Mode=OneWay}"
                                              IsHitTestVisible="False"
                                              Style="{DynamicResource BlogDataGridCheckBox}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" Text="$ Ожидание ответа..."
                   FontFamily="{StaticResource MonoFont}" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasResponse}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
