<UserControl x:Class="SoloReq.Views.RequestPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:converters="clr-namespace:SoloReq.Converters"
             Background="Transparent">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- URL Bar -->
        <Border Grid.Row="0" CornerRadius="8" Background="{DynamicResource EditorBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="4" Margin="0,4,0,4" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Method Selector -->
                <ComboBox Grid.Column="0" ItemsSource="{Binding Methods}" SelectedItem="{Binding SelectedMethod}"
                          Style="{DynamicResource BlogComboBox}"
                          MinWidth="100"/>

                <!-- Scheme Prefix -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0"
                           FontFamily="{StaticResource MonoFont}" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="https://"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SslVerificationDisabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Text" Value="http://"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- URL Input -->
                <TextBox Grid.Column="2" x:Name="UrlTextBox"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource MonoFont}" FontSize="13"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="8,6" Margin="0,0,4,0"
                         VerticalContentAlignment="Center">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return"
                                    Command="{Binding DataContext.SendRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Send Button -->
                <Border Grid.Column="3" CornerRadius="8" ClipToBounds="True">
                    <Button Content="&gt;&gt; Отправить"
                            Command="{Binding DataContext.SendRequestCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontFamily="{StaticResource MonoFont}" FontSize="13" FontWeight="Bold"
                            Foreground="White" Padding="16,6" Cursor="Hand"
                            BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF479C" Offset="0"/>
                                <GradientStop Color="#FF9248" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>

                <!-- SSL Toggle -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <CheckBox IsChecked="{Binding DataContext.SslVerificationDisabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}}"
                              Style="{DynamicResource BlogDataGridCheckBox}"/>
                    <TextBlock Text="SSL" FontFamily="{StaticResource MonoFont}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="1" Height="3" Margin="0,0,0,4"
                Visibility="{Binding DataContext.IsLoading, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border CornerRadius="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" x:Name="LoadingGradient">
                        <GradientStop Color="#FF479C" Offset="0"/>
                        <GradientStop Color="#FF9248" Offset="0.5"/>
                        <GradientStop Color="#FF479C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Border.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetName="LoadingTransform"
                                                 Storyboard.TargetProperty="X"
                                                 From="-200" To="200" Duration="0:0:1.5"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="LoadingTransform"/>
                </Border.RenderTransform>
            </Border>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Style="{DynamicResource BlogTabControl}">

            <!-- Body Tab -->
            <TabItem Header="// Тело" Style="{DynamicResource BlogTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Body toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,4,0,4">
                        <Button Content="Форматировать" Command="{Binding FormatJsonCommand}"
                                Style="{DynamicResource ToolbarTagButton}" Margin="0,0,4,0"/>
                        <Button Content="Минифицировать" Command="{Binding MinifyJsonCommand}"
                                Style="{DynamicResource ToolbarTagButton}"/>
                    </StackPanel>

                    <!-- AvalonEdit for request body -->
                    <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True"
                            Background="{DynamicResource EditorBackgroundBrush}">
                        <Border.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource EditorScrollBarStyle}"/>
                        </Border.Resources>
                    <avalonedit:TextEditor x:Name="BodyEditor"
                                           FontFamily="{StaticResource MonoFont}" FontSize="13"
                                           Background="Transparent"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           ShowLineNumbers="True"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           IsEnabled="{Binding IsBodyEnabled}"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Headers Tab -->
            <TabItem Header="// Заголовки" Style="{DynamicResource BlogTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="+ Добавить" Command="{Binding AddHeaderCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,4"
                            FontFamily="{StaticResource MonoFont}" FontSize="11"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Padding="8,4" Cursor="Hand"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Headers}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              Style="{DynamicResource BlogDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{DynamicResource BlogDataGridCheckBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ключ" Binding="{Binding Key}" Width="*"
                                                Foreground="{DynamicResource TextPrimaryBrush}">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Значение" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding Value}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Margin="2,0,26,0" TextTrimming="CharacterEllipsis"/>
                                            <Button Content="☰" HorizontalAlignment="Right"
                                                    Width="24" Height="20" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    FontSize="12" Cursor="Hand"
                                                    Click="OpenUserAgentPicker">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Key}" Value="User-Agent">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="{DynamicResource EditorBackgroundBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0" Padding="2,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="10"
                                                Command="{Binding DataContext.RemoveHeaderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Auth Tab -->
            <TabItem Header="// Авторизация" Style="{DynamicResource BlogTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8">
                    <StackPanel>
                        <TextBlock Text="Тип авторизации:" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding AuthTypes}" SelectedItem="{Binding AuthType}"
                                  Style="{DynamicResource BlogComboBox}"
                                  Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left"/>

                        <!-- Basic Auth -->
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuthType}" Value="Basic">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Логин:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AuthUsername}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,0,8"/>
                            <TextBlock Text="Пароль:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AuthPassword}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6"/>
                        </StackPanel>

                        <!-- Bearer Token -->
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuthType}" Value="Bearer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Токен:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding AuthToken}" MinWidth="200" MaxWidth="600" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6"/>
                        </StackPanel>

                        <!-- API Key -->
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuthType}" Value="ApiKey">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Имя ключа:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApiKeyName}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,0,8"/>
                            <TextBlock Text="Значение:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ApiKeyValue}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Передавать в:" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding ApiKeyLocations}" SelectedItem="{Binding ApiKeyLocation}"
                                          Style="{DynamicResource BlogComboBox}"
                                          MaxWidth="200" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Custom Header -->
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AuthType}" Value="Custom">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Имя заголовка:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CustomHeaderName}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" Margin="0,0,0,8"/>
                            <TextBlock Text="Значение:" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding CustomHeaderValue}" MinWidth="200" MaxWidth="400" HorizontalAlignment="Left"
                                     FontFamily="{StaticResource MonoFont}" FontSize="12"
                                     Background="{DynamicResource EditorBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" Padding="8,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Query Params Tab -->
            <TabItem Header="// Параметры" Style="{DynamicResource BlogTabItem}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="+ Добавить" Command="{Binding AddQueryParamCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,4"
                            FontFamily="{StaticResource MonoFont}" FontSize="11"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" Padding="8,4" Cursor="Hand"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding QueryParams}" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              Style="{DynamicResource BlogDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{DynamicResource BlogDataGridCheckBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ключ" Binding="{Binding Key}" Width="*"
                                                Foreground="{DynamicResource TextPrimaryBrush}">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"
                                                Foreground="{DynamicResource TextPrimaryBrush}">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" FontSize="10"
                                                Command="{Binding DataContext.RemoveQueryParamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
