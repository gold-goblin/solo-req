<Window x:Class="SoloReq.Views.ThemePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=">_ Выберите тему"
        Width="460" Height="340"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None" AllowsTransparency="false"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}">
            <TextBlock Text="&gt;_ Выберите тему" VerticalAlignment="Center" Margin="12,0,0,0"
                       FontFamily="{StaticResource MonoFont}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Grid>

        <!-- Content -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Logo -->
            <TextBlock HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                       FontSize="22" FontWeight="Bold" Margin="0,0,0,20">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF479C" Offset="0"/>
                        <GradientStop Color="#FF9248" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
                &gt;_ Добро пожаловать в solo-req
            </TextBlock>

            <!-- Theme cards -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                <!-- Dark theme card -->
                <Border x:Name="DarkCard" Width="180" Height="120" Margin="0,0,12,0"
                        CornerRadius="12" BorderThickness="2" Cursor="Hand"
                        BorderBrush="#3A3A4A" Background="#0A0A0F"
                        MouseLeftButtonDown="DarkTheme_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Canvas Width="24" Height="24">
                                <Path Data="M21,12.79 A9,9 0 1,1 11.21,3 A7,7 0 0,0 21,12.79 Z"
                                      Stroke="#E0E0E8" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Тёмная" FontFamily="{StaticResource MonoFont}" FontSize="14"
                                   HorizontalAlignment="Center" Foreground="#E0E0E8" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Ellipse Width="10" Height="10" Fill="#0A0A0F" Stroke="#3A3A4A" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#14141C" Stroke="#3A3A4A" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#1A1A24" Stroke="#3A3A4A" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#FF479C" Margin="2,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Light theme card -->
                <Border x:Name="LightCard" Width="180" Height="120" Margin="12,0,0,0"
                        CornerRadius="12" BorderThickness="2" Cursor="Hand"
                        BorderBrush="#D0D0D8" Background="#F5F5FA"
                        MouseLeftButtonDown="LightTheme_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Canvas Width="24" Height="24">
                                <Path Data="M12,1 L12,3 M12,21 L12,23 M4.22,4.22 L5.64,5.64 M18.36,18.36 L19.78,19.78 M1,12 L3,12 M21,12 L23,12 M4.22,19.78 L5.64,18.36 M18.36,5.64 L19.78,4.22"
                                      Stroke="#1A1A24" StrokeThickness="1.5"
                                      StrokeLineJoin="Round"/>
                                <Path Data="M17,12 A5,5 0 1,1 7,12 A5,5 0 1,1 17,12"
                                      Stroke="#1A1A24" StrokeThickness="1.5"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Светлая" FontFamily="{StaticResource MonoFont}" FontSize="14"
                                   HorizontalAlignment="Center" Foreground="#1A1A24" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Ellipse Width="10" Height="10" Fill="#FFFFFF" Stroke="#D0D0D8" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#F5F5FA" Stroke="#D0D0D8" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#EAEAF0" Stroke="#D0D0D8" StrokeThickness="1" Margin="2,0"/>
                            <Ellipse Width="10" Height="10" Fill="#FF479C" Margin="2,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Hint -->
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                       MaxWidth="400">
                <Run Text="$ Вы всегда можете сменить тему"/>
                <LineBreak/>
                <Run Text="клавишей F12 или кнопкой "/>
                <InlineUIContainer BaselineAlignment="Center">
                    <Viewbox Width="14" Height="14" Margin="0,0,1,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M21,12.79 A9,9 0 1,1 11.21,3 A7,7 0 0,0 21,12.79 Z"
                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" Fill="Transparent"/>
                        </Canvas>
                    </Viewbox>
                </InlineUIContainer>
                <Run Text="/"/>
                <InlineUIContainer BaselineAlignment="Center">
                    <Viewbox Width="14" Height="14" Margin="1,0,0,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12,1 L12,3 M12,21 L12,23 M4.22,4.22 L5.64,5.64 M18.36,18.36 L19.78,19.78 M1,12 L3,12 M21,12 L23,12 M4.22,19.78 L5.64,18.36 M18.36,5.64 L19.78,4.22"
                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round"/>
                            <Path Data="M17,12 A5,5 0 1,1 7,12 A5,5 0 1,1 17,12"
                                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.5"
                                  StrokeLineJoin="Round" Fill="Transparent"/>
                        </Canvas>
                    </Viewbox>
                </InlineUIContainer>
                <Run Text=" в заголовке окна"/>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
