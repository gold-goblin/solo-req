<UserControl x:Class="SoloReq.Views.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SoloReq.Converters"
             xmlns:models="clr-namespace:SoloReq.Models"
             Background="Transparent">

    <UserControl.Resources>
        <converters:StatusSuccessBrushConverter x:Key="StatusSuccessBrushConverter"/>

        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="// История" Margin="12,12,12,8"
                   FontFamily="{StaticResource MonoFont}" FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <!-- History Groups -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:HistoryGroup}">
                        <Border Background="{DynamicResource PanelBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="8,2" Padding="0" CornerRadius="12"
                                x:Name="GroupBorder">
                            <StackPanel>
                                <!-- Group header: URL + delete group -->
                                <Grid Margin="10,8,10,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayUrl}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="✕" FontSize="10"
                                            FontFamily="{StaticResource MonoFont}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Cursor="Hand" Padding="4,0" Margin="4,0,0,0"
                                            Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            CommandParameter="{Binding}"
                                            x:Name="DeleteGroupBtn">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <!-- Flat entry rows sorted by method -->
                                <ItemsControl ItemsSource="{Binding SortedEntries}" Margin="0,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:HistoryItem}">
                                            <Border Padding="10,4" Cursor="Hand"
                                                    MouseLeftButtonDown="HistoryEntry_Click"
                                                    Background="Transparent"
                                                    x:Name="EntryRowBorder">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <!-- Name display + rename button on same line -->
                                                    <StackPanel Orientation="Horizontal" Margin="8,0,0,2"
                                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="# "/><Run Text="{Binding Name, Mode=OneWay, TargetNullValue=''}"/>
                                                        </TextBlock>
                                                        <Button Content="✎" FontSize="10"
                                                                FontFamily="{StaticResource MonoFont}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                                Cursor="Hand" Padding="3,0" Margin="2,0,0,0"
                                                                Click="RenameButton_Click"
                                                                x:Name="RenameBtn">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>

                                                    <!-- Name editing TextBox (visible when IsEditing) -->
                                                    <StackPanel Orientation="Horizontal" Margin="8,0,0,2"
                                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="# " FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                                 FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                                 Background="Transparent"
                                                                 BorderBrush="{DynamicResource AccentPinkBrush}"
                                                                 BorderThickness="0,0,0,1"
                                                                 MinWidth="100" Padding="2,1"
                                                                 KeyDown="RenameTextBox_KeyDown"
                                                                 LostFocus="RenameTextBox_LostFocus"
                                                                 Loaded="RenameTextBox_Loaded"
                                                                 CaretBrush="{DynamicResource TextPrimaryBrush}"/>
                                                    </StackPanel>

                                                    <!-- Method info row -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Method -->
                                                        <TextBlock Grid.Column="0" Text="{Binding Request.Method}" FontWeight="Bold"
                                                                   FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Margin="8,0,6,0" VerticalAlignment="Center"/>

                                                        <!-- Status code -->
                                                        <TextBlock Grid.Column="1" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                                   Foreground="{Binding Response.StatusCode, Converter={StaticResource StatusSuccessBrushConverter}}"
                                                                   Text="{Binding Response.StatusCode}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                        <!-- Elapsed -->
                                                        <TextBlock Grid.Column="2" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding Response.ElapsedMs, StringFormat={}{0}мс}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>

                                                        <!-- Relative time -->
                                                        <TextBlock Grid.Column="3" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding Timestamp, Converter={StaticResource RelativeTimeConverter}}"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                   Margin="0,0,4,0"/>

                                                        <!-- Delete entry button (hover) -->
                                                        <Button Grid.Column="4" Content="✕" FontSize="10"
                                                                FontFamily="{StaticResource MonoFont}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                                Cursor="Hand" Padding="3,0"
                                                                Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                CommandParameter="{Binding}"
                                                                x:Name="DeleteEntryBtn">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <!-- Repeat button -->
                                                        <Button Grid.Column="5" Content="&gt;&gt;" FontSize="10"
                                                                FontFamily="{StaticResource MonoFont}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                                Cursor="Hand" Padding="4,0"
                                                                Command="{Binding DataContext.RepeatCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=EntryRowBorder}" Value="True">
                                                    <Setter TargetName="RenameBtn" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="DeleteEntryBtn" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter TargetName="RenameBtn" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=GroupBorder}" Value="True">
                                <Setter TargetName="DeleteGroupBtn" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Clear button -->
        <Button Grid.Row="2" Content="Очистить" Margin="8,4,8,8"
                Command="{Binding ClearHistoryCommand}"
                FontFamily="{StaticResource MonoFont}" FontSize="11"
                Foreground="{DynamicResource TextSecondaryBrush}"
                Background="Transparent"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Padding="8,6" Cursor="Hand"/>
    </Grid>
</UserControl>
