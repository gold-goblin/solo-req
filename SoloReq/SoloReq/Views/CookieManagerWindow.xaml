<Window x:Class="SoloReq.Views.CookieManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=">_ Менеджер Cookies"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStyle="None" AllowsTransparency="false"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="6"
                      GlassFrameThickness="0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource WindowBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Bold">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF479C" Offset="0"/>
                            <GradientStop Color="#FF9248" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    &gt;_
                </TextBlock>
                <TextBlock Text=" Менеджер Cookies" FontFamily="{StaticResource MonoFont}" FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="✕" Click="CloseClick" HorizontalAlignment="Right"
                    FontSize="12" Width="40" Height="32"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Auto-send toggle -->
            <CheckBox Grid.Row="0" Content="Автоматически отправлять cookies"
                      IsChecked="{Binding AutoSendEnabled}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      FontFamily="{StaticResource MonoFont}" FontSize="12"
                      Margin="0,0,0,12"/>

            <!-- Add cookie form -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="10" Margin="0,0,0,8" CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewName}" Margin="0,0,4,0"
                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                             Background="{DynamicResource EditorBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" Padding="6,4"
                             Tag="Имя"/>
                    <TextBox Grid.Column="1" Text="{Binding NewValue}" Margin="0,0,4,0"
                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                             Background="{DynamicResource EditorBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" Padding="6,4"
                             Tag="Значение"/>
                    <TextBox Grid.Column="2" Text="{Binding NewDomain}" Margin="0,0,4,0"
                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                             Background="{DynamicResource EditorBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" Padding="6,4"
                             Tag="Домен"/>
                    <TextBox Grid.Column="3" Text="{Binding NewPath}" Width="50" Margin="0,0,4,0"
                             FontFamily="{StaticResource MonoFont}" FontSize="11"
                             Background="{DynamicResource EditorBackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" Padding="6,4"/>
                    <Button Grid.Column="4" Content="+" Command="{Binding AddCookieCommand}"
                            FontFamily="{StaticResource MonoFont}" FontSize="14"
                            Foreground="White" Width="32" Cursor="Hand" BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF479C" Offset="0"/>
                                <GradientStop Color="#FF9248" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>
            </Border>

            <!-- Cookie list -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding Cookies}" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True"
                      Style="{DynamicResource BlogDataGrid}"
                      BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                      FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"/>
                    <DataGridTextColumn Header="Домен" Binding="{Binding Domain}" Width="Auto"/>
                    <DataGridTextColumn Header="Путь" Binding="{Binding Path}" Width="50"/>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" FontSize="10"
                                        Command="{Binding DataContext.RemoveCookieCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource ErrorBrush}" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Clear all button -->
            <Button Grid.Row="3" Content="Очистить все" Command="{Binding ClearAllCommand}"
                    HorizontalAlignment="Left" Margin="0,8,0,0"
                    FontFamily="{StaticResource MonoFont}" FontSize="11"
                    Foreground="{DynamicResource ErrorBrush}"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Padding="12,6" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
